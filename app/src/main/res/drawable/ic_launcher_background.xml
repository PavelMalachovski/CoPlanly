<?xml version="1.0" encoding="utf-8"?>
<!-- Violet launcher-icon background, matching the splash gradient (#6750A4 -> #4F46E5)
     so the icon and the startup screen share one violet colour. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF6750A4" />
                <item android:offset="1.0" android:color="#FF4F46E5" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
