rules_version = '2';

// Production Firestore rules for CoPlanly.
//
// These rules are aligned with the ACTUAL document schema the app writes
// (EventRepositoryImpl.toFirestoreMap / SyncService): date fields are ISO
// *strings*, not Firestore timestamps, and documents carry the full field set
// (~18 keys for events), not a fixed minimal subset. Earlier versions of this
// file validated `is timestamp` and an exact key set, which rejected every
// real write — that is why the permissive `firestore.rules.simple` had to be
// deployed instead. Keep these in sync with `toFirestoreMap()`.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPartnerOf(userId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.partnerId == request.auth.uid;
    }

    // Validate string field length (inclusive bounds).
    function isValidLength(str, minLen, maxLen) {
      return str is string && str.size() >= minLen && str.size() <= maxLen;
    }

    // ---- Users ---------------------------------------------------------
    // Users can read/write their own profile and read their partner's profile.
    match /users/{userId} {
      allow read: if isOwner(userId) || isPartnerOf(userId);

      allow create: if isOwner(userId) &&
                      'email' in request.resource.data &&
                      'name' in request.resource.data &&
                      isValidLength(request.resource.data.name, 1, 100) &&
                      (!('firebaseUid' in request.resource.data) ||
                       request.resource.data.firebaseUid == null ||
                       request.resource.data.firebaseUid == request.auth.uid);

      allow update: if isOwner(userId) &&
                      (!('firebaseUid' in request.resource.data) ||
                       request.resource.data.firebaseUid == null ||
                       request.resource.data.firebaseUid == request.auth.uid);

      allow delete: if isOwner(userId);
    }

    // ---- Events --------------------------------------------------------
    // Owners and shared partners have access. Date fields are ISO strings, so
    // no timestamp-type or ordering checks here (that is enforced app-side).
    match /events/{eventId} {
      allow read: if isAuthenticated() && (
        resource.data.createdByFirebaseUid == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith
      );

      // Presence-based validation only — the real document carries the full
      // schema, so an exact key-set match must NOT be required.
      allow create: if isAuthenticated() &&
                      request.resource.data.createdByFirebaseUid == request.auth.uid &&
                      request.resource.data.keys().hasAll(['title', 'startDateTime', 'eventType', 'parentOwner']) &&
                      isValidLength(request.resource.data.title, 1, 200);

      // Creator, or a partner with read_write permission, may update. The creator
      // field is immutable. lastModifiedBy is intentionally NOT required to equal
      // the caller: the client doesn't reliably stamp the editor on every write
      // path, and forcing it here silently denied legitimate partner edits.
      allow update: if isAuthenticated() && (
        resource.data.createdByFirebaseUid == request.auth.uid ||
        (request.auth.uid in resource.data.sharedWith &&
         resource.data.permissions == 'read_write')
      ) && request.resource.data.createdByFirebaseUid == resource.data.createdByFirebaseUid;

      allow delete: if isAuthenticated() &&
                      resource.data.createdByFirebaseUid == request.auth.uid;
    }

    // ---- Child info ----------------------------------------------------
    // Shared between a parent pair via the sharedWith list.
    match /child_info/{childInfoId} {
      allow read: if isAuthenticated() &&
                    request.auth.uid in resource.data.sharedWith;

      allow create: if isAuthenticated() &&
                      request.resource.data.createdByFirebaseUid == request.auth.uid &&
                      request.auth.uid in request.resource.data.sharedWith &&
                      request.resource.data.keys().hasAll(['childName', 'createdByFirebaseUid', 'sharedWith']) &&
                      isValidLength(request.resource.data.childName, 1, 100);

      allow update: if isAuthenticated() &&
                      request.auth.uid in resource.data.sharedWith &&
                      request.resource.data.createdByFirebaseUid == resource.data.createdByFirebaseUid;

      allow delete: if isAuthenticated() &&
                      resource.data.createdByFirebaseUid == request.auth.uid;
    }

    // ---- Expenses (receipt sync) --------------------------------------
    // Only the two paired parents involved may read/write.
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (
        resource.data.createdByFirebaseUid == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith
      );

      allow create: if isAuthenticated() &&
                      request.resource.data.createdByFirebaseUid == request.auth.uid;

      allow update: if isAuthenticated() && (
        resource.data.createdByFirebaseUid == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith
      ) && request.resource.data.createdByFirebaseUid == resource.data.createdByFirebaseUid;

      allow delete: if isAuthenticated() &&
                      resource.data.createdByFirebaseUid == request.auth.uid;
    }

    // ---- Change requests ----------------------------------------------
    // Event change requests: only the requester or the addressee may access.
    match /change_requests/{requestId} {
      allow read, update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.requestedBy ||
        request.auth.uid == resource.data.requestedTo
      );

      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.requestedBy ||
        request.auth.uid == request.resource.data.requestedTo
      );
    }

    // ---- Invitations ---------------------------------------------------
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        (request.auth.token.email != null && resource.data.toEmail == request.auth.token.email)
      );

      allow create: if isAuthenticated() &&
                      request.resource.data.fromUserId == request.auth.uid &&
                      'toEmail' in request.resource.data &&
                      'status' in request.resource.data &&
                      'createdAt' in request.resource.data &&
                      request.resource.data.status == 'pending';

      allow update: if isAuthenticated() && (
        (request.auth.token.email != null && resource.data.toEmail == request.auth.token.email &&
         request.resource.data.status in ['accepted', 'rejected']) ||
        (resource.data.fromUserId == request.auth.uid &&
         request.resource.data.status == 'cancelled')
      ) && resource.data.status == 'pending';

      allow delete: if isAuthenticated() &&
                      resource.data.fromUserId == request.auth.uid;
    }

    // ---- Notification queue -------------------------------------------
    // Drained by a Cloud Function; clients may only enqueue.
    match /notification_queue/{notificationId} {
      allow read: if false;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ---- Custody schedules --------------------------------------------
    match /custody_schedules/{scheduleId} {
      allow read, update, delete: if isAuthenticated() && (
        resource.data.momUserId == request.auth.uid ||
        resource.data.dadUserId == request.auth.uid
      );

      allow create: if isAuthenticated() && (
        request.resource.data.momUserId == request.auth.uid ||
        request.resource.data.dadUserId == request.auth.uid
      );
    }
  }
}
