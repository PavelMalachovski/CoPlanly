rules_version = '2';

// Cloud Storage rules for CoPlanly.
//
// Receipt photos are stored at receipts/{expenseId}.jpg. Reads and writes require
// authentication; download URLs embedded in Firestore documents carry an access
// token and keep working for the paired parent regardless of these read rules.
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{fileName} {
      allow read: if request.auth != null;
      // Deletes have request.resource == null; uploads must be JPEG under 5 MB.
      allow write: if request.auth != null
        && (request.resource == null
            || (request.resource.size < 5 * 1024 * 1024
                && request.resource.contentType == 'image/jpeg'));
    }

    // Event photos, stored at event_images/{eventId}.jpg, same constraints as receipts.
    match /event_images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.resource == null
            || (request.resource.size < 5 * 1024 * 1024
                && request.resource.contentType == 'image/jpeg'));
    }

    // Everything else is closed by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
